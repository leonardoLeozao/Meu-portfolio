programa{
  funcao inicio(){

   real distancia
   real litros
   real consumo
   escreva("Digite a distância percorrida em km: ")
   leia(distancia)

   escreva("Digite a quantidade de combustível gasto em litros: ")
   leia(litros)

   consumo = distancia * 0.10 

   escreva("O consumo médio do veículo é: ", consumo)
   }

}
